{
  "name": "signup-automation",
  "version": "1.0.0",
  "description": "Playwright automation for the Authorized Partner signup flow (Page Object Model, JavaScript).",
  "type": "commonjs",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "PWDEBUG=1 playwright test",
